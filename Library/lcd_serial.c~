#include <io.h>
#include <delay.h>
#include "lcd_serial.h"

void KernelShift(unsigned char y){

    unsigned char x = 0b00000000;
    unsigned char i;
    
    DDRMOD |= (1<<SH_CP_ShiftClock) | (1<<DS_Data) | (1<<ST_CP_Latch); 

    for(i=0; i<8; i++){
        x = 1 << i;
        delay_us(1);

        if(x & y){
            PORTSR |= (1<<DS_Data);
        }        
        else{ 
            PORTSR &= ~(1<<DS_Data);       
        }
                
        PORTSR |= (1<<SH_CP_ShiftClock);        
        delay_us(1);            
        PORTSR &= ~(1<<SH_CP_ShiftClock); 
    }
        
    PORTSR |= (1<<ST_CP_Latch);        
    delay_us(1);            
    PORTSR &= ~(1<<ST_CP_Latch);        
}

void BitSerial_Send(unsigned char g, unsigned char moz){

    if(moz == 0){ // CMD Mode
        // High nibble 
        KernelShift(((g>>2) & 0b00111100) | (1 << 6));
        delay_us(1);             
        KernelShift(((g>>2) & 0b00111100) & ~(1 << 6)); 
        delay_us(1);             
        
        // Low nibble 
        KernelShift(((g<<2) & 0b00111100) | (1 << 6));
        delay_us(1);             
        KernelShift(((g<<2) & 0b00111100) & ~(1 << 6));
        delay_us(1);             
    } 
    
    if(moz == 1){ // Char Mode
        // High nibble 
        KernelShift(((g >> 2) & 0b00111100) | (1 << 6) | (1 << 7));
        delay_us(1);                                                 
        KernelShift((((g >> 2) & 0b00111100) & ~(1 << 6)) | (1 << 7));
        delay_us(1);             

        // Low nibble 
        KernelShift(((g << 2) & 0b00111100) | (1 << 6) | (1 << 7));
        delay_us(1);             
        KernelShift((((g << 2) & 0b00111100) & ~(1 << 6)) | (1 << 7));
        delay_us(1);             
    }     
    
    if(moz == 2){ // 8-Bit Initialization Mode
        KernelShift(((g >> 2) & 0b00111100) | (1 << 6));
        delay_us(5);             
        KernelShift(((g >> 2) & 0b00111100) & ~(1 << 6));
        delay_us(5);             
    }
}

void LCD_init(void){
    // Initialization procedure according to HD44780 Datasheet, Page 46, Figure 24! 
    
    delay_ms(50); // Wait for more than 40 ms after VCC rises to 2.7V
    
    BitSerial_Send(0b00110000, 2);
    delay_ms(5); // Wait for more than 4.1 ms
    
    BitSerial_Send(0b00110000, 2);
    delay_us(150); // Wait for more than 100 us
    
    BitSerial_Send(0b00110000, 2);
    delay_us(40); // Instruction execution time > 37 us
    
    BitSerial_Send(0b00100000, 2); // FUNCTION SET: 4-BIT MODE
    delay_us(40); // Instruction execution time > 37 us
    
    BitSerial_Send(0b00101000, 0); // FUNCTION SET: 2-Line, 5x8 dots
    delay_us(40); // Instruction execution time > 37 us
    
    BitSerial_Send(0b00001100, 0); // DISPLAY ON/OFF CONTROL: Display ON, Cursor OFF
    delay_us(40); // Instruction execution time > 37 us
    
    BitSerial_Send(0b00000001, 0); // CLEAR DISPLAY
    delay_ms(2); // Execution time max 1.52 ms
    
    BitSerial_Send(0b00000110, 0); // ENTRY MODE SET: Increment by 1, No Shift
    delay_us(40); // Instruction execution time > 37 us
}

void lcd_putchar(unsigned char x){
    BitSerial_Send(x, 1);
    delay_us(40); // Write data to DDRAM execution time > 37 us
} 
    
void lcd_gotoxy(unsigned char x, unsigned char y){
    // Commands in Page 12: DDRAM address
    if(y == 0){
        BitSerial_Send(0x80 + x, 0);
    }
    if (y == 1){
        BitSerial_Send(0xC0 + x, 0);
    }
    delay_us(40); // Set DDRAM address execution time > 37 us
}

void lcd_Clear(void){
    // Table 6, PAGE 24: Clear display execution time is 1.52 ms 
    BitSerial_Send(0b00000001, 0);
    delay_ms(2); 
}

void lcd_puts(char *str){
    while(*str != '\0'){
        lcd_putchar(*str); // Using lcd_putchar to ensure the 40 us delay is applied per character
        str++;
    }
}